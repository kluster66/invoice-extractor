# Configuration AWS (optionnel - utilise AWS CLI par défaut)
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=votre_access_key_id
# AWS_SECRET_ACCESS_KEY=votre_secret_access_key
# AWS_SESSION_TOKEN=votre_session_token_optionnelle

# Configuration Bedrock
# Modèles disponibles :
# - us.anthropic.claude-haiku-4-5-20251001-v1:0 (recommandé - Claude Haiku 4.5, inference profile)
# - meta.llama3-1-70b-instruct-v1:0 (pas d'activation requise mais moins précis)
# Note : les modèles Claude 4.x nécessitent le préfixe "us." (cross-region inference profile)
# Attention : les modèles "Legacy" dans Bedrock sont bloqués après 30j sans usage
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MAX_TOKENS=1000
BEDROCK_TEMPERATURE=0.1

# Configuration DynamoDB
DYNAMODB_TABLE_NAME=invoices-extractor
DYNAMODB_READ_CAPACITY=5
DYNAMODB_WRITE_CAPACITY=5

# Configuration S3
# Remplacer {votre-account-id} par votre Account ID AWS (aws sts get-caller-identity)
S3_INPUT_BUCKET=invoice-input-{votre-account-id}-us-west-2
S3_PROCESSED_PREFIX=processed/
S3_ERROR_PREFIX=error/

# Configuration Application
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
MAX_PDF_SIZE_MB=50
TEMP_DIR=/tmp
EXTRACTION_TIMEOUT=300  # 5 minutes en secondes
MAX_RETRY_ATTEMPTS=3

# Notes :
# 1. L'application utilise AWS CLI par défaut (aws configure)
# 2. Pour changer de modèle : Config.set_model('claude-3-haiku')
# 3. Pour tester : python test_models_simple.py
# 4. Pour lister les modèles : python list_available_models.py
